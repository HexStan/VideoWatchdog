[global]

# 最多保留的日志文件数
max_log_files = 7

# 日志保存目录
log_dir = "logs"

# ==================================================

# 允许配置多组任务，这里是第一组任务
[[tasks]]

name = "Task 1"

# 指定监控目录 (待处理目录)，必填
monitor_dir = "./input"

# 指定输出目录，必填
output_dir = "./output"

# 指定处理完成后的源文件移动目录，必填
processed_dir = "./processed"

# 指定要识别并处理的文件格式（扩展名），如果不指定，则默认只识别 mp4 文件
input_formats = ["mp4", "mkv", "avi"]

# 遍历时间间隔（秒），为0则作为一次性脚本运行一次后退出
scan_interval = 60

# 文件修改时间阈值（秒），为0则不以修改时间为筛选条件
file_mtime = 300

# 检测文件大小变化的时间间隔（秒），为0则不检测大小变化
stable_duration = 5

# 最多重试次数
max_retries = 3

# 要执行的FFMpeg命令，{input} 和 {output} 会被自动替换为实际路径，必填
# 支持多行命令，执行时会自动合并为单行
ffmpeg_cmd = """
ffmpeg -y \
  -i "{input}" \
  -c:v libx264 \
  -preset fast \
  -crf 23 \
  "{output}"
"""

# 输出文件名的后缀
suffix = "encoded"

# 输出文件的格式
output_format = "mp4"

# ==================================================

# 第二组任务示例 (可选)
# [[tasks]]
# name = "Task 2"
# monitor_dir = "./input2"
# output_dir = "./output2"
# processed_dir = "./done2"
